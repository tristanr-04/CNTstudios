# Contactformulier: e-mail via Gmail SMTP (app-wachtwoord in Google-account)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cntstudios26@gmail.com
SMTP_PASS=

# Ontvanger (standaard hetzelfde als hierboven)
CONTACT_TO_EMAIL=cntstudios26@gmail.com

# Optioneel: afzenderkop in inbox
# SMTP_FROM=CNTstudios <cntstudios26@gmail.com>

# Productie: alleen POST /api/contact vanaf deze origins (komma-gescheiden, geen slash aan het eind).
# Voorbeeld: https://cntstudios.nl,https://www.cntstudios.nl
# Laat leeg tijdens development; zet aan zodra je live gaat.
# ALLOWED_ORIGINS=
