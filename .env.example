# Contactformulier: e-mail via Gmail SMTP (app-wachtwoord in Google-account)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cntstudios26@gmail.com
SMTP_PASS=

# Ontvanger (standaard hetzelfde als hierboven)
CONTACT_TO_EMAIL=cntstudios26@gmail.com

# Optioneel: afzenderkop in inbox
# SMTP_FROM=CNTstudios <cntstudios26@gmail.com>

# Optioneel: canonieke URL voor sitemap / robots (https, geen slash aan het eind).
# Zonder deze var gebruikt de build https://cntstudios.nl — niet meer *.vercel.app (Search Console).
# Alleen zetten als je www wilt: NEXT_PUBLIC_SITE_URL=https://www.cntstudios.nl
# NEXT_PUBLIC_SITE_URL=
#
# Telefoon op WiFi: pnpm dev luistert standaard op alle interfaces (0.0.0.0).
# Next.js allowlist voor 192.168.x / 10.x / 172.16.x staat automatisch in next.config (development).
# Alleen zetten als je hostnaam gebruikt (geen IP): LAN_DEV_ORIGINS=mijn-macbook.local
# Optioneel tijdens LAN-test: NEXT_PUBLIC_SITE_URL=http://192.168.178.51:3000

# Productie (Vercel): alleen POST /api/contact vanaf deze sites. Komma-gescheiden, geen slash aan het eind.
# www en niet-www worden gelijk behandeld. Vercel voegt zelf https://jouw-project.vercel.app toe (VERCEL_URL).
# Lokaal (pnpm dev) wordt nooit geblokkeerd. Laat leeg om de check helemaal uit te zetten.
# Voorbeeld (één regel): https://cntstudios.nl,https://www.cntstudios.nl
# ALLOWED_ORIGINS=

# Klantenportaal (/login, /portal/[slug]): min. 24 willekeurige tekens (openssl rand -hex 32)
# PORTAL_SESSION_SECRET=
#
# Accounts JSON-array, één regel in Vercel. Wachtwoord: bcrypt hash (zie scripts/portal-hash-password.mjs)
# Voorbeeld (lokaal testen, één demo-klant):
# PORTAL_USERS_JSON=[{"username":"demo","passwordHash":"$2a$10$VERVANG_DIT_MET_HASH","slug":"demo"}]
#
# Statische demo per klant: map demo/[slug]/ in de repo (index.html + css/js/img). Zelfde slug als hierboven.
